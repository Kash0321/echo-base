@page "/acerca-de"
@attribute [Authorize]

<PageTitle>Acerca de Echo Base</PageTitle>

<!-- ═══════════════════════════════════════════════════
     HERO
═══════════════════════════════════════════════════ -->
<div class="eb-about-hero text-white text-center py-4 mb-3">
    <div class="container">
        <p class="eb-about-eyebrow text-uppercase fw-semibold mb-1">Strategic Docking Coordinator</p>
        <h1 class="display-5 fw-bold mb-1">
            <i class="bi bi-stars me-2"></i>Echo Base
        </h1>
        <p class="small mb-0 opacity-75 fst-italic">
            "La precisión no es un lujo. Es la única forma de que todos aterricen."
        </p>
    </div>
</div>

<div class="container pb-3">

    <!-- ═══════════════════════════════════════════════════
         LORE: HISTORIA DEL NOMBRE
    ═══════════════════════════════════════════════════ -->
    <div class="row justify-content-center mb-3">
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm eb-lore-card">
                <div class="card-body p-3">
                    <h2 class="h6 text-uppercase fw-bold text-secondary mb-3 d-flex align-items-center gap-2">
                        <i class="bi bi-journal-text text-primary fs-5"></i>La historia detrás del nombre
                    </h2>

                    <div class="row g-3">

                        <!-- Pilar 1: Hoth -->
                        <div class="col-md-4">
                            <div class="eb-lore-pillar h-100">
                                <div class="eb-lore-pillar-icon mb-2">
                                    <i class="bi bi-snow2 text-primary fs-3"></i>
                                </div>
                                <h5 class="h6 fw-bold mb-2">El planeta Hoth</h5>
                                <p class="small text-secondary mb-0">
                                    En <em>El Imperio Contraataca</em>, la Alianza Rebelde estableció
                                    su cuartel general en el planeta helado de Hoth, bajo el nombre
                                    clave <strong>Echo Base</strong>. Una base temporal, táctica,
                                    diseñada para que las unidades puedan operar, coordinarse y
                                    partir hacia la siguiente misión. No es un hogar permanente:
                                    es un punto de apoyo estratégico.
                                </p>
                            </div>
                        </div>

                        <!-- Pilar 2: La oficina híbrida -->
                        <div class="col-md-4">
                            <div class="eb-lore-pillar h-100">
                                <div class="eb-lore-pillar-icon mb-2">
                                    <i class="bi bi-building text-primary fs-3"></i>
                                </div>
                                <h5 class="h6 fw-bold mb-2">La oficina del futuro</h5>
                                <p class="small text-secondary mb-0">
                                    El trabajo híbrido redefine para qué sirve la oficina.
                                    Ya no es el lugar donde <em>siempre</em> estás: es el lugar
                                    al que <em>acudes con propósito</em>. Como los pilotos rebeldes
                                    que despejan su X-Wing de la bahía de atraque cuando hay misión,
                                    y la liberan cuando terminan. Cada puesto es una
                                    <strong>docking bay</strong> esperando su siguiente nave.
                                </p>
                            </div>
                        </div>

                        <!-- Pilar 3: El principio del palomar -->
                        <div class="col-md-4">
                            <div class="eb-lore-pillar h-100">
                                <div class="eb-lore-pillar-icon mb-2">
                                    <i class="bi bi-diagram-3-fill text-primary fs-3"></i>
                                </div>
                                <h5 class="h6 fw-bold mb-2">El principio del palomar</h5>
                                <p class="small text-secondary mb-0">
                                    70 unidades rebeldes. 24 bahías de atraque.
                                    El <strong>principio del palomar</strong> dicta que si hay más
                                    palomas que palomares, al menos un palomar tendrá más de una
                                    paloma. Aquí, la asignación precisa y coordinada es la única
                                    forma de que todos tengan sitio cuando lo necesitan
                                    y nadie lo ocupe cuando no está.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         STACK TECNOLÓGICO
    ═══════════════════════════════════════════════════ -->
    <div class="row justify-content-center mb-3">
        <div class="col-lg-9">
            <h2 class="h6 text-uppercase fw-bold text-secondary mb-2 d-flex align-items-center gap-2">
                <i class="bi bi-cpu text-primary"></i>Stack tecnológico
            </h2>
            <div class="row g-2">

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-braces text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">.NET 10</p>
                        <p class="text-secondary" style="font-size:.72rem;">C# · Blazor Web App</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-layout-sidebar text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">Interactive Server</p>
                        <p class="text-secondary" style="font-size:.72rem;">SignalR · SSR</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-bootstrap text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">Bootstrap 5</p>
                        <p class="text-secondary" style="font-size:.72rem;">+ Bootstrap Icons</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-database text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">Entity Framework Core</p>
                        <p class="text-secondary" style="font-size:.72rem;">SQLite · Azure SQL</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-arrow-left-right text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">MediatR</p>
                        <p class="text-secondary" style="font-size:.72rem;">CQRS · Clean Architecture</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-shield-lock text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">Azure AD</p>
                        <p class="text-secondary" style="font-size:.72rem;">Microsoft Identity Web</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-envelope-at text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">SMTP + Teams</p>
                        <p class="text-secondary" style="font-size:.72rem;">Notificaciones push</p>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-2 h-100 eb-tech-card">
                        <i class="bi bi-check2-square text-primary fs-3 mb-1"></i>
                        <p class="fw-semibold small mb-0">xUnit + NSubstitute</p>
                        <p class="text-secondary" style="font-size:.72rem;">Unit · Integration tests</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         CRÉDITOS
    ═══════════════════════════════════════════════════ -->
    <div class="row justify-content-center mb-2">
        <div class="col-lg-9">
