                    <div class="card border-0 shadow-sm h-100 eb-credit-card-human">
                        <div class="card-body p-3 d-flex gap-3">
                            <div class="eb-avatar-human flex-shrink-0">
                                <i class="bi bi-person-badge-fill text-white fs-3"></i>
                            </div>
                            <div>
