                                       class="btn btn-sm eb-btn-linkedin">
                                        <i class="bi bi-linkedin me-1"></i>LinkedIn
                                    </a>
                                    <a href="https://x.com/sergio_castillo"
                                       target="_blank" rel="noopener noreferrer"
                                       class="btn btn-sm eb-btn-x">
                                        <i class="bi bi-twitter-x me-1"></i>&#64;sergio_castillo
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Copilot -->
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100 eb-credit-card-ai">
                        <div class="card-body p-3 d-flex gap-3">
                            <div class="eb-avatar-ai flex-shrink-0">
                                <i class="bi bi-robot text-white fs-3"></i>
                            </div>
                            <div>
                                <p class="fw-bold mb-0">GitHub Copilot Pro</p>
                                <p class="small text-secondary mb-2">
                                    Pair programmer de IA — arquitectura, código, tests y UX
                                </p>
                                <div class="d-flex flex-column gap-1">
                                    <span class="eb-ai-chip">
                                        <i class="bi bi-cpu me-1 text-primary"></i>
                                        <strong>Modelo:</strong> Claude Sonnet 4.6 (Anthropic)
                                    </span>
                                    <span class="eb-ai-chip">
                                        <i class="bi bi-search me-1 text-primary"></i>
                                        <strong>Agentes:</strong> Explore · Search subagent
                                    </span>
                                    <span class="eb-ai-chip">
                                        <i class="bi bi-terminal me-1 text-primary"></i>
                                        <strong>Skills:</strong> agent-customization
                                    </span>
                                </div>
