            </div>
        </div>
    </div>

    <!-- Versión -->
    <div class="row justify-content-center">
        <div class="col-lg-9 text-center">
            <p class="text-secondary" style="font-size:.72rem;">
                Echo Base v1.0 &middot; .NET 10 &middot; Marzo 2026
                &middot; <span class="text-primary fw-semibold">May the Force be with you</span>
            </p>
        </div>
