    private static string FormatAuditAction(AuditAction action) => action switch
    {
        AuditAction.ReservationCreated          => "Reserva creada",
        AuditAction.ReservationCancelled        => "Reserva cancelada",
        AuditAction.DockBlocked                 => "Puesto bloqueado",
        AuditAction.DockUnblocked               => "Puesto desbloqueado",
        AuditAction.BulkReservationsCancelled   => "Cancelación masiva",
        AuditAction.MaintenanceModeChanged      => "Modo mantenimiento",
        AuditAction.EmergencyReservationCreated => "Reserva emergencia",
        AuditAction.UserRoleAssigned            => "Rol asignado",
        AuditAction.UserRoleRemoved             => "Rol retirado",
        _                                       => action.ToString()
    };

    private static string FormatSlot(TimeSlot slot) => slot switch
    {
        TimeSlot.Morning   => "Mañana",
        TimeSlot.Afternoon => "Tarde",
        TimeSlot.Both      => "Ambas",
        _                  => slot.ToString()
    };

    private static string MapSystemAdminError(string error) => error switch
    {
        "NOT_SYSTEM_ADMIN"    => "No tienes permisos de SystemAdmin para realizar esta acción.",
        "USER_NOT_FOUND"      => "El usuario seleccionado no existe.",
        "INVALID_ROLE"        => "El rol indicado no es válido.",
        "ROLE_ALREADY_ASSIGNED" => "El usuario ya tiene ese rol asignado.",
        "ROLE_NOT_ASSIGNED"   => "El usuario no tiene ese rol.",
        "INVALID_DATE_RANGE"  => "La fecha de fin no puede ser anterior a la de inicio.",
        _                     => $"Error inesperado: {error}"
    };

    private static string MapReservationError(string error) => error switch
    {
        "DATE_IN_THE_PAST"       => "La fecha no puede ser anterior a hoy.",
        "DATE_TOO_FAR_AHEAD"     => "La fecha no puede superar los 7 días de antelación.",
        "DOCK_NOT_FOUND"         => "El puesto seleccionado no existe.",
        "DOCK_BLOCKED"           => "El puesto está bloqueado para esa fecha.",
        "DOCK_NOT_AVAILABLE"     => "El puesto ya está reservado en esa franja.",
        "USER_MAX_SLOTS_EXCEEDED" => "El usuario ha alcanzado el máximo de franjas diarias.",
        "USER_SLOT_CONFLICT"     => "El usuario ya tiene una reserva que se solaparía.",
        _                        => $"Error: {error}"
    };

    // ── DTO local para simplificar la lista de puestos ─────────────
    private sealed record DockSimpleDto(Guid Id, string Code);
}
