                <div class="modal-header eb-modal-header">
                    <h5 class="modal-title text-white fw-bold mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Eliminar zona
                    </h5>
                </div>
                <div class="modal-body">
                    <p class="mb-0">¿Eliminar la zona <strong>@_dcDeleteZoneName</strong>?
                    Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDeleteZone">Cancelar</button>
                    <button class="btn btn-danger btn-sm" disabled="@_dcSaving"
                            @onclick="ConfirmDeleteZoneAsync">
