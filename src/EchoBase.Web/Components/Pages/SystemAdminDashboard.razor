    private static string GetZoneFlexClass(DockZoneMapDto zone) =>
        zone.Orientation == ZoneOrientation.Vertical ? "flex-column align-items-start" : "flex-row flex-wrap";

    private static string GetBtnClass(DockSeatDto seat) => seat.Status switch
    {
        DockStatus.Free           => "btn-success",
        DockStatus.PartiallyBooked => "btn-warning",
        DockStatus.FullyBooked    => "btn-danger",
        DockStatus.Blocked        => "btn-secondary",
        _                         => "btn-outline-secondary"
    };

    private static string GetTooltip(DockSeatDto seat) => seat.Status switch
    {
        DockStatus.Free           => "Libre — haz clic para reservar",
        DockStatus.PartiallyBooked => BuildPartialTooltip(seat),
        DockStatus.FullyBooked    => BuildFullBookedTooltip(seat),
        DockStatus.Blocked        => BuildBlockedTooltip(seat),
        _                         => seat.Code
    };

    private static string BuildPartialTooltip(DockSeatDto seat)
    {
        var slot = FormatSlot(seat.BookedSlot!.Value);
        var who = seat.BookedSlot!.Value == TimeSlot.Morning ? seat.MorningBookedBy : seat.AfternoonBookedBy;
        return string.IsNullOrEmpty(who) ? $"Parcial — {slot} ocupada" : $"Parcial — {slot} ocupada ({who})";
    }

    private static string BuildFullBookedTooltip(DockSeatDto seat)
    {
        if (seat.MorningBookedBy is null && seat.AfternoonBookedBy is null) return "Completo";
        if (seat.MorningBookedBy == seat.AfternoonBookedBy && seat.MorningBookedBy is not null)
            return $"Completo — {seat.MorningBookedBy}";
        var parts = new List<string>();
        if (seat.MorningBookedBy is not null) parts.Add($"Mañana: {seat.MorningBookedBy}");
        if (seat.AfternoonBookedBy is not null) parts.Add($"Tarde: {seat.AfternoonBookedBy}");
        return "Completo — " + string.Join(", ", parts);
    }

    private static string BuildBlockedTooltip(DockSeatDto seat)
    {
        var by = string.IsNullOrEmpty(seat.BlockedByName) ? "" : $" por {seat.BlockedByName}";
        var reason = string.IsNullOrEmpty(seat.BlockReason) ? "" : $": {seat.BlockReason}";
        return $"Bloqueado{by}{reason}";
    }

    private static IEnumerable<TimeSlot> GetAvailableSlots(DockSeatDto seat)
    {
        if (seat.Status == DockStatus.Free)
        {
            yield return TimeSlot.Morning;
            yield return TimeSlot.Afternoon;
            yield return TimeSlot.Both;
        }
        else if (seat.Status == DockStatus.PartiallyBooked && seat.BookedSlot is not null)
        {
            yield return seat.BookedSlot.Value == TimeSlot.Morning ? TimeSlot.Afternoon : TimeSlot.Morning;
        }
    }

