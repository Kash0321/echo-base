                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDeleteTable">Cancelar</button>
                    <button class="btn btn-danger btn-sm" disabled="@_dcSaving"
                            @onclick="ConfirmDeleteTableAsync">
                        @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Eliminar
