@page "/system-admin"
@attribute [Authorize(Roles = "SystemAdmin")]
@rendermode InteractiveServer

@using EchoBase.Core.BlockedDocks.Queries
@using EchoBase.Core.DockAdmin.Commands
@using EchoBase.Core.DockAdmin.Queries
@using EchoBase.Core.Entities.Enums
@using EchoBase.Core.Interfaces
@using EchoBase.Core.Reservations.Queries
@using EchoBase.Core.SystemAdmin.Commands
@using EchoBase.Core.SystemAdmin.Queries
@using EchoBase.Web.Services
@using MediatR

@inject IMediator Mediator
@inject BlazorCurrentUserService CurrentUser

<PageTitle>Administración del sistema — Echo Base</PageTitle>

<!-- ═══════════════════════════════════════════════════
     CABECERA DE PÁGINA
═══════════════════════════════════════════════════ -->
<div class="eb-page-header text-white py-2 mb-3">
    <div class="container-fluid px-3">
        <p class="eb-page-eyebrow text-uppercase fw-semibold mb-0">Echo Base</p>
        <h1 class="h4 fw-bold mb-0">
            <i class="bi bi-shield-lock-fill me-2"></i>Administración del sistema
        </h1>
    </div>
</div>

<div class="container-fluid px-3">

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    <!-- ═══ PESTAÑAS DE NAVEGACIÓN ═══════════════════════════════════ -->
    <ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.Maintenance ? "active" : "")"
                    @onclick='() => _activeTab = Tab.Maintenance'>
                <i class="bi bi-tools me-1 @(_maintenanceActive ? "text-warning" : "")"></i>
                Mantenimiento
                @if (_maintenanceActive)
                {
                    <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem;">ACTIVO</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.DockConfig ? "active" : "")"
                    @onclick='() => SwitchToDockConfigTab()'>
                <i class="bi bi-buildings-fill text-primary me-1"></i>Zonas y puestos
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.BulkCancel ? "active" : "")"
                    @onclick='() => _activeTab = Tab.BulkCancel'>
                <i class="bi bi-calendar-x text-danger me-1"></i>Cancelación masiva
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.Emergency ? "active" : "")"
                    @onclick='() => _activeTab = Tab.Emergency'>
                <i class="bi bi-lightning-charge-fill text-warning me-1"></i>Reserva de emergencia
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.Users ? "active" : "")"
                    @onclick='() => _activeTab = Tab.Users'>
                <i class="bi bi-people-fill text-primary me-1"></i>Usuarios
                <span class="badge bg-secondary ms-1" style="font-size:.65rem;">@_allUsers.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(_activeTab == Tab.AuditLog ? "active" : "")"
                    @onclick='() => SwitchToAuditTab()'>
                <i class="bi bi-journal-text text-primary me-1"></i>Log de auditoría
            </button>
        </li>
    </ul>

    <!-- ═══ PESTAÑA: MODO MANTENIMIENTO ══════════════════════════════ -->
    @if (_activeTab == Tab.Maintenance)
    {
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Cuando está activo, los usuarios no pueden realizar reservas ni acceder al sistema.
            Los SystemAdmins no se ven afectados.
        </p>
        <div class="mb-3">
            <label for="maintReason" class="form-label form-label-sm fw-semibold">Motivo</label>
            <input type="text" id="maintReason" class="form-control form-control-sm"
                    placeholder="Ej: Actualización de servidores..."
                    @bind="_maintenanceReason" />
        </div>
        @if (_maintError is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span class="small">@_maintError</span>
            </div>
        }
        @if (_maintSuccess is not null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span class="small">@_maintSuccess</span>
            </div>
        }
        <div class="d-flex gap-2">
            <button class="btn btn-warning btn-sm flex-fill"
                    disabled="@(_settingMaintenance || _maintenanceActive)"
                    @onclick="ActivateMaintenance">
                @if (_settingMaintenance && !_maintenanceActive)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-tools me-1"></i>
                }
                Activar
            </button>
            <button class="btn btn-outline-secondary btn-sm flex-fill"
                    disabled="@(_settingMaintenance || !_maintenanceActive)"
                    @onclick="DeactivateMaintenance">
                @if (_settingMaintenance && _maintenanceActive)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-check2-circle me-1"></i>
                }
                Desactivar
            </button>
        </div>
    }

    <!-- ═══ PESTAÑA ZONAS Y PUESTOS ═════════════════════════════════════ -->
    @if (_activeTab == Tab.DockConfig)
    {
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Gestiona las zonas físicas, las mesas y los puestos de trabajo.
            Al eliminar un puesto se cancelarán automáticamente sus reservas futuras.
        </p>

        @if (_dcError is not null)
        {
            <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@_dcError</span>
                <button type="button" class="btn-close ms-auto" @onclick='() => _dcError = null'></button>
            </div>
        }
        @if (_dcSuccess is not null)
        {
            <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@_dcSuccess</span>
                <button type="button" class="btn-close ms-auto" @onclick='() => _dcSuccess = null'></button>
            </div>
        }

        <!-- ── Lista de zonas ─────────────────────────────────────────────── -->
        @if (_dcLoadingZones)
        {
            <div class="d-flex justify-content-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando zonas…</span>
                </div>
            </div>
        }
        else
        {
            @foreach (var zone in _dockZones)
            {
                <div class="card border-0 shadow-sm mb-3"
                     @key="zone.Id"
                     @ondragover:preventDefault
                     @ondrop="() => OnZoneDrop(zone.Id)">
                    <!-- Cabecera de zona -->
                    <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-2">
                        <span draggable="true"
                              @ondragstart="() => _dragSourceZoneId = zone.Id"
                              class="text-secondary lh-1"
                              style="cursor:grab;" title="Arrastrar para reordenar zona">
                            <i class="bi bi-grip-vertical fs-5"></i>
                        </span>
                        <button class="btn btn-link p-0 text-secondary lh-1"
                                title="@(_dcExpandedZones.Contains(zone.Id) ? "Colapsar zona" : "Expandir zona")"
                                @onclick="() => { if (!_dcExpandedZones.Remove(zone.Id)) _dcExpandedZones.Add(zone.Id); }">
                            <i class="bi @(_dcExpandedZones.Contains(zone.Id) ? "bi-chevron-down" : "bi-chevron-right") fs-5"></i>
                        </button>
                        <i class="bi bi-buildings-fill text-primary fs-5"></i>
                        @if (_dcEditingZoneId == zone.Id)
                        {
                            <!-- Formulario edición de zona — controles a anchura completa -->
                            <div class="d-flex flex-wrap gap-2 align-items-center flex-grow-1">
                                <div class="input-group input-group-sm" style="flex:1 1 140px; min-width:140px;">
                                    <input class="form-control" placeholder="Nombre" @bind="_dcZoneName" />
                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                            @onclick='() => _dcZoneName = string.Empty'>
                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                    </button>
                                </div>
                                <div class="input-group input-group-sm" style="flex:2 1 200px; min-width:200px;">
                                    <input class="form-control" placeholder="Descripción (opcional)" @bind="_dcZoneDescription" />
                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                            @onclick='() => _dcZoneDescription = string.Empty'>
                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                    </button>
                                </div>
                                <div class="d-flex gap-1" role="group">
                                    <input type="radio" class="btn-check" id="ori-h-@zone.Id"
                                           name="ori-@zone.Id" value="@ZoneOrientation.Horizontal"
                                           checked="@(_dcZoneOrientation == ZoneOrientation.Horizontal)"
                                           @onchange='() => _dcZoneOrientation = ZoneOrientation.Horizontal' />
                                    <label class="btn btn-outline-secondary btn-sm" for="ori-h-@zone.Id" title="Orientación horizontal (mesas una al lado de la otra)">
                                        <i class="bi bi-arrow-right"></i> H
                                    </label>
                                    <input type="radio" class="btn-check" id="ori-v-@zone.Id"
                                           name="ori-@zone.Id" value="@ZoneOrientation.Vertical"
                                           checked="@(_dcZoneOrientation == ZoneOrientation.Vertical)"
                                           @onchange='() => _dcZoneOrientation = ZoneOrientation.Vertical' />
                                    <label class="btn btn-outline-secondary btn-sm" for="ori-v-@zone.Id" title="Orientación vertical (mesas una debajo de la otra)">
                                        <i class="bi bi-arrow-down"></i> V
                                    </label>
                                </div>
                            </div>
                            <!-- Botones de acción al final, en la zona de acciones -->
                            <div class="d-flex gap-1 flex-shrink-0">
                                <button class="btn btn-success btn-sm" disabled="@_dcSaving"
                                        @onclick="() => SaveEditZoneAsync(zone.Id)">
                                    @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Guardar
                                </button>
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="CancelEditZone">Cancelar</button>
                            </div>
                        }
                        else
                        {
                            <span class="fw-semibold flex-grow-1">
                                @zone.Name
                                @if (!string.IsNullOrEmpty(zone.Description))
                                {
                                    <small class="text-muted fw-normal ms-2">@zone.Description</small>
                                }
                                <span class="badge bg-secondary ms-2" style="font-size:.65rem;">
                                    @(zone.Orientation == ZoneOrientation.Horizontal ? "Horizontal" : "Vertical")
                                </span>
                            </span>
                            <div class="d-flex gap-1">
                                <button class="btn btn-outline-primary btn-sm py-0"
                                        title="Editar zona"
                                        @onclick="() => StartEditZone(zone)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm py-0"
                                        title="Eliminar zona"
                                        @onclick="() => RequestDeleteZone(zone.Id, zone.Name)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>

                    @if (_dcExpandedZones.Contains(zone.Id))
                    {
                    <div class="card-body p-3">
                        <!-- ── Mesas ─────────────────────────────────────────────────── -->
                        <h6 class="fw-semibold text-muted text-uppercase small mb-2">
                            <i class="bi bi-layout-three-columns me-1"></i>Mesas
                            <span class="badge bg-secondary ms-1">@zone.Tables.Count</span>
                        </h6>

                        @if (zone.Tables.Count == 0)
                        {
                            <p class="text-muted small mb-2">Sin mesas configuradas.</p>
                        }
                        else
                        {
                            <div class="table-responsive mb-2">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Clave</th>
                                            <th>Localizador</th>
                                            <th class="text-end">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var tbl in zone.Tables)
                                        {
                                            <tr @key="tbl.Id"
                                                @ondragover:preventDefault
                                                @ondrop="() => OnTableDrop(tbl.Id, zone)">
                                                @if (_dcEditingTableId == tbl.Id)
                                                {
                                                    <td class="py-1">
                                                        <div class="input-group input-group-sm">
                                                            <input class="form-control font-monospace" placeholder="Clave"
                                                                   @bind="_dcTableKey" />
                                                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                                    @onclick='() => _dcTableKey = string.Empty'>
                                                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                    <td class="py-1">
                                                        <div class="input-group input-group-sm">
                                                            <input class="form-control" placeholder="Localizador (opcional)"
                                                                   @bind="_dcTableLocator" />
                                                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                                    @onclick='() => _dcTableLocator = string.Empty'>
                                                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                    <td class="py-1 text-end" style="width:1%">
                                                        <div class="d-flex gap-1 justify-content-end">
                                                            <button class="btn btn-success btn-sm" disabled="@_dcSaving"
                                                                    @onclick="() => SaveEditTableAsync(tbl.Id)">
                                                                @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                Guardar
                                                            </button>
                                                            <button class="btn btn-outline-secondary btn-sm"
                                                                    @onclick="CancelEditTable">Cancelar</button>
                                                        </div>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td class="font-monospace small">
                                                        <span draggable="true"
                                                              @ondragstart="() => { _dragSourceTableId = tbl.Id; _dragTableSourceZoneId = zone.Id; }"
                                                              class="text-secondary me-1"
                                                              style="cursor:grab; vertical-align:middle;"
                                                              title="Arrastrar para reordenar mesa">
                                                            <i class="bi bi-grip-vertical"></i>
                                                        </span>
                                                        @tbl.TableKey
                                                    </td>
                                                    <td class="small text-muted">@(tbl.Locator ?? "—")</td>
                                                    <td class="text-end">
                                                        <button class="btn btn-outline-primary btn-sm py-0"
                                                                title="Editar mesa"
                                                                @onclick="() => StartEditTable(tbl)">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-sm py-0"
                                                                title="Eliminar mesa"
                                                                @onclick="() => RequestDeleteTable(tbl.Id, tbl.TableKey)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <!-- Formulario nueva mesa -->
                        @if (_dcNewTableZoneId == zone.Id)
                        {
                            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                <div class="input-group input-group-sm" style="flex:0 1 150px; min-width:110px;">
                                    <input class="form-control" placeholder="Clave (ej: N)" @bind="_dcNewTableKey" />
                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                            @onclick='() => _dcNewTableKey = string.Empty'>
                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                    </button>
                                </div>
                                <div class="input-group input-group-sm" style="flex:1 1 200px; min-width:160px;">
                                    <input class="form-control" placeholder="Localizador (opcional)" @bind="_dcNewTableLocator" />
                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                            @onclick='() => _dcNewTableLocator = string.Empty'>
                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                    </button>
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0">
                                    <button class="btn btn-success btn-sm" disabled="@_dcSaving"
                                            @onclick="() => CreateTableAsync(zone.Id)">
                                        @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-plus me-1"></i>Añadir
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="CancelNewTable">Cancelar</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm mb-2"
                                    @onclick="() => StartNewTable(zone.Id)">
                                <i class="bi bi-plus me-1"></i>Nueva mesa
                            </button>
                        }

                        <hr class="my-2" />

                        <!-- ── Puestos (agrupados por mesa) ──────────────────────────── -->
                        <h6 class="fw-semibold text-muted text-uppercase small mb-2">
                            <i class="bi bi-person-workspace me-1"></i>Puestos
                            <span class="badge bg-secondary ms-1">@zone.Tables.Sum(t => t.Docks.Count)</span>
                        </h6>

                        @foreach (var tbl in zone.Tables)
                        {
                            <div class="mb-3">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="fw-medium small font-monospace">Mesa @tbl.TableKey</span>
                                    @if (tbl.Locator is not null)
                                    {
                                        <span class="text-muted small">— @tbl.Locator</span>
                                    }
                                </div>
                                @if (tbl.Docks.Count == 0)
                                {
                                    <p class="text-muted small mb-1">Sin puestos en esta mesa.</p>
                                }
                                else
                                {
                                    <div class="table-responsive mb-1">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Código</th>
                                                    <th>Lado</th>
                                                    <th>Ubicación</th>
                                                    <th>Equipamiento</th>
                                                    <th class="text-end">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var dock in tbl.Docks)
                                                {
                                                    <tr>
                                                        @if (_dcEditingDockId == dock.Id)
                                                        {
                                                            <td class="py-1">
                                                                <div class="input-group input-group-sm">
                                                                    <input class="form-control" placeholder="Código"
                                                                           @bind="_dcDockCode" />
                                                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                                            @onclick='() => _dcDockCode = string.Empty'>
                                                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td class="py-1" style="width:1%">
                                                                <div class="d-flex gap-1" role="group">
                                                                    <input type="radio" class="btn-check" id="edit-dock-side-a-@dock.Id"
                                                                           checked="@(_dcDockSide == DockSide.A)"
                                                                           @onchange='() => _dcDockSide = DockSide.A' />
                                                                    <label class="btn btn-outline-secondary btn-sm" for="edit-dock-side-a-@dock.Id">A</label>
                                                                    <input type="radio" class="btn-check" id="edit-dock-side-b-@dock.Id"
                                                                           checked="@(_dcDockSide == DockSide.B)"
                                                                           @onchange='() => _dcDockSide = DockSide.B' />
                                                                    <label class="btn btn-outline-secondary btn-sm" for="edit-dock-side-b-@dock.Id">B</label>
                                                                </div>
                                                            </td>
                                                            <td class="py-1">
                                                                <div class="input-group input-group-sm">
                                                                    <input class="form-control" placeholder="Ubicación"
                                                                           @bind="_dcDockLocation" />
                                                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                                            @onclick='() => _dcDockLocation = string.Empty'>
                                                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td class="py-1">
                                                                <div class="input-group input-group-sm">
                                                                    <input class="form-control" placeholder="Equipamiento"
                                                                           @bind="_dcDockEquipment" />
                                                                    <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                                            @onclick='() => _dcDockEquipment = string.Empty'>
                                                                        <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td class="py-1 text-end" style="width:1%">
                                                                <div class="d-flex gap-1 justify-content-end">
                                                                    <button class="btn btn-success btn-sm"
                                                                            disabled="@_dcSaving"
                                                                            @onclick="() => SaveEditDockAsync(dock.Id)">
                                                                        @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                        Guardar
                                                                    </button>
                                                                    <button class="btn btn-outline-secondary btn-sm"
                                                                            @onclick="CancelEditDock">Cancelar</button>
                                                                </div>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td class="font-monospace small fw-semibold">@dock.Code</td>
                                                            <td class="small text-muted">@dock.Side</td>
                                                            <td class="small">@dock.Location</td>
                                                            <td class="small text-muted">@dock.Equipment</td>
                                                            <td class="text-end">
                                                                <button class="btn btn-outline-primary btn-sm py-0"
                                                                        title="Editar puesto"
                                                                        @onclick="() => StartEditDock(dock)">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>
                                                                <button class="btn btn-outline-danger btn-sm py-0"
                                                                        title="Eliminar puesto (cancela reservas futuras)"
                                                                        @onclick="() => RequestDeleteDock(dock.Id, dock.Code)">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                                <!-- Formulario nuevo puesto para esta mesa -->
                                @if (_dcNewDockTableId == tbl.Id)
                                {
                                    <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                        <div class="input-group input-group-sm" style="flex:0 1 110px; min-width:90px;">
                                            <input class="form-control" placeholder="Código" @bind="_dcNewDockCode" />
                                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                    @onclick='() => _dcNewDockCode = string.Empty'>
                                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                            </button>
                                        </div>
                                        <div class="d-flex gap-1" role="group">
                                            <input type="radio" class="btn-check" id="new-dock-side-a-@tbl.Id"
                                                   checked="@(_dcNewDockSide == DockSide.A)"
                                                   @onchange='() => _dcNewDockSide = DockSide.A' />
                                            <label class="btn btn-outline-secondary btn-sm" for="new-dock-side-a-@tbl.Id">Lado A</label>
                                            <input type="radio" class="btn-check" id="new-dock-side-b-@tbl.Id"
                                                   checked="@(_dcNewDockSide == DockSide.B)"
                                                   @onchange='() => _dcNewDockSide = DockSide.B' />
                                            <label class="btn btn-outline-secondary btn-sm" for="new-dock-side-b-@tbl.Id">Lado B</label>
                                        </div>
                                        <div class="input-group input-group-sm" style="flex:1 1 160px; min-width:140px;">
                                            <input class="form-control" placeholder="Ubicación" @bind="_dcNewDockLocation" />
                                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                    @onclick='() => _dcNewDockLocation = string.Empty'>
                                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                            </button>
                                        </div>
                                        <div class="input-group input-group-sm" style="flex:2 1 180px; min-width:160px;">
                                            <input class="form-control" placeholder="Equipamiento" @bind="_dcNewDockEquipment" />
                                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                                    @onclick='() => _dcNewDockEquipment = string.Empty'>
                                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                            </button>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            <button class="btn btn-success btn-sm" disabled="@_dcSaving"
                                                    @onclick="() => CreateDockAsync(tbl.Id)">
                                                @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                <i class="bi bi-plus me-1"></i>Añadir
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="CancelNewDock">Cancelar</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="() => StartNewDock(tbl.Id)">
                                        <i class="bi bi-plus me-1"></i>Nuevo puesto
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    }
                </div>
            }

            <!-- ── Crear nueva zona ───────────────────────────────────────── -->
            <div class="card border-0 shadow-sm border-dashed">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-plus-circle text-primary me-1"></i>Nueva zona
                    </h6>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <div class="input-group input-group-sm" style="flex:1 1 160px; min-width:130px;">
                            <span class="input-group-text">Nombre</span>
                            <input class="form-control" placeholder="Ej: Zona 1" @bind="_dcNewZoneName" />
                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                    @onclick='() => _dcNewZoneName = string.Empty'>
                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                            </button>
                        </div>
                        <div class="input-group input-group-sm" style="flex:2 1 200px; min-width:160px;">
                            <span class="input-group-text">Descripción</span>
                            <input class="form-control" placeholder="Opcional" @bind="_dcNewZoneDescription" />
                            <button class="btn btn-outline-secondary" type="button" title="Limpiar"
                                    @onclick='() => _dcNewZoneDescription = string.Empty'>
                                <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                            </button>
                        </div>
                        <div class="d-flex gap-1" role="group">
                            <input type="radio" class="btn-check" id="new-ori-h"
                                   checked="@(_dcNewZoneOrientation == ZoneOrientation.Horizontal)"
                                   @onchange='() => _dcNewZoneOrientation = ZoneOrientation.Horizontal' />
                            <label class="btn btn-outline-secondary btn-sm" for="new-ori-h" title="Orientación horizontal (mesas una al lado de la otra)">
                                <i class="bi bi-arrow-right me-1"></i>H
                            </label>
                            <input type="radio" class="btn-check" id="new-ori-v"
                                   checked="@(_dcNewZoneOrientation == ZoneOrientation.Vertical)"
                                   @onchange='() => _dcNewZoneOrientation = ZoneOrientation.Vertical' />
                            <label class="btn btn-outline-secondary btn-sm" for="new-ori-v" title="Orientación vertical (mesas una debajo de la otra)">
                                <i class="bi bi-arrow-down me-1"></i>V
                            </label>
                        </div>
                        <div class="d-flex gap-1 flex-shrink-0">
                            <button class="btn btn-primary btn-sm" disabled="@_dcSaving"
                                    @onclick="CreateZoneAsync">
                                @if (_dcSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plus me-1"></i>Crear zona
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- ═══ PESTAÑA: CANCELACIÓN MASIVA ══════════════════════════════ -->
    @if (_activeTab == Tab.BulkCancel)
    {
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Cancela todas las reservas activas en el rango de fechas indicado.
            Selecciona puestos concretos para afectar solo a ellos, o deja todos sin seleccionar para cancelar todos.
        </p>
        <!-- Fechas y motivo -->
        <div class="row g-2 mb-3">
            <div class="col-sm-6 col-md-3">
                <label for="bulkStart" class="form-label form-label-sm fw-semibold">Fecha inicio</label>
                <input type="date" id="bulkStart" class="form-control form-control-sm"
                        value="@_bulkStartDate.ToString("yyyy-MM-dd")"
                        @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _bulkStartDate = d; }" />
            </div>
            <div class="col-sm-6 col-md-3">
                <label for="bulkEnd" class="form-label form-label-sm fw-semibold">Fecha fin</label>
                <input type="date" id="bulkEnd" class="form-control form-control-sm"
                        value="@_bulkEndDate.ToString("yyyy-MM-dd")"
                        min="@_bulkStartDate.ToString("yyyy-MM-dd")"
                        @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _bulkEndDate = d; }" />
            </div>
            <div class="col-md-6">
                <label for="bulkReason" class="form-label form-label-sm fw-semibold">Motivo</label>
                <input type="text" id="bulkReason" class="form-control form-control-sm"
                        placeholder="Ej: Cierre por condiciones climáticas..."
                        @bind="_bulkReason" />
            </div>
        </div>

        <!-- Mapa de puestos (estilo DockMap) -->
        @if (_bulkDockMap is not null)
        {
            <div class="mb-3">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="form-label form-label-sm fw-semibold mb-0">
                        Puestos a cancelar
                        <span class="text-muted fw-normal">(sin selección = todos)</span>
                    </span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="eb-legend-dot bg-danger"></span><span class="small text-muted">Seleccionado</span>
                        <span class="eb-legend-dot bg-success"></span><span class="small text-muted">No seleccionado</span>
                    </div>
                    @if (_bulkSelectedDockIds.Count > 0)
                    {
                        <button class="btn btn-link btn-sm p-0 text-muted" @onclick="() => _bulkSelectedDockIds.Clear()">
                            <i class="bi bi-x-circle me-1"></i>Limpiar selección (@_bulkSelectedDockIds.Count)
                        </button>
                    }
                </div>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var zone in _bulkDockMap.Zones)
                    {
                        <div class="card border-0 shadow-sm">
                            <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-1 px-2">
                                <i class="bi bi-grid-3x3 text-primary"></i>
                                <span class="fw-semibold small">@zone.Name</span>
                            </div>
                            <div class="card-body py-2 px-3">
                                <div class="d-flex @GetZoneFlexClass(zone) gap-3">
                                    @foreach (var table in zone.Tables)
                                    {
                                        <div class="eb-table-block">
                                            <p class="text-muted small fw-semibold mb-1">@(table.Locator ?? table.Name)</p>
                                            <div class="eb-dock-table">
                                                <div class="d-flex gap-2 mb-1">
                                                    @foreach (var seat in table.SideA)
                                                    {
                                                        var isSelected = _bulkSelectedDockIds.Contains(seat.Id);
                                                        <button class="btn @(isSelected ? "btn-danger" : "btn-outline-secondary") eb-dock-seat eb-dock-seat-toggle"
                                                                title="@seat.Code — @(isSelected ? "clic para deseleccionar" : "clic para seleccionar")"
                                                                @onclick="() => ToggleBulkDock(seat.Id)">
                                                            @seat.Code
                                                        </button>
                                                    }
                                                </div>
                                                <hr class="eb-dock-divider my-1" />
                                                <div class="d-flex gap-2">
                                                    @foreach (var seat in table.SideB)
                                                    {
                                                        var isSelected = _bulkSelectedDockIds.Contains(seat.Id);
                                                        <button class="btn @(isSelected ? "btn-danger" : "btn-outline-secondary") eb-dock-seat eb-dock-seat-toggle"
                                                                title="@seat.Code — @(isSelected ? "clic para deseleccionar" : "clic para seleccionar")"
                                                                @onclick="() => ToggleBulkDock(seat.Id)">
                                                            @seat.Code
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_bulkError is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span class="small">@_bulkError</span>
            </div>
        }
        @if (_bulkSuccess is not null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span class="small">@_bulkSuccess</span>
            </div>
        }
        @if (_confirmBulkCancel)
        {
            <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                <span class="small flex-fill">
                    ¿Confirmas la cancelación masiva del @_bulkStartDate.ToString("dd/MM/yyyy")
                    al @_bulkEndDate.ToString("dd/MM/yyyy")
                    @(_bulkSelectedDockIds.Count > 0 ? $"({_bulkSelectedDockIds.Count} puesto(s) seleccionado(s))" : "(todos los puestos)")?
                    Esta acción notificará a todos los afectados.
                </span>
                <div class="d-flex gap-1 ms-2">
                    <button class="btn btn-danger btn-sm" @onclick="ConfirmBulkCancel">Sí, cancelar</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _confirmBulkCancel = false">No</button>
                </div>
            </div>
        }
        else
        {
            <button class="btn btn-danger btn-sm"
                    disabled="@(string.IsNullOrWhiteSpace(_bulkReason) || _bulkCancelling)"
                    @onclick="RequestBulkCancel">
                @if (_bulkCancelling)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-calendar-x me-1"></i>
                }
                Cancelar reservas
            </button>
        }
    }

    <!-- ═══ PESTAÑA: RESERVA DE EMERGENCIA ═══════════════════════════ -->
    @if (_activeTab == Tab.Emergency)
    {
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Crea una reserva en nombre de un usuario. Se aplican todas las validaciones normales.
            Selecciona el usuario, la fecha y haz clic en un puesto del mapa.
        </p>
        <!-- Usuario y fecha -->
        <div class="row g-2 mb-3">
            <div class="col-sm-6 col-lg-4">
                <label for="erUser" class="form-label form-label-sm fw-semibold">Usuario</label>
                <select id="erUser" class="form-select form-select-sm"
                        @onchange="OnEmergencyUserChanged">
                    <option value="">— Selecciona usuario —</option>
                    @foreach (var u in _allUsers)
                    {
                        <option value="@u.Id" selected="@(_emergencyTargetUserId == u.Id)">@u.Name (@u.Email)</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-lg-3">
                <label for="erDate" class="form-label form-label-sm fw-semibold">Fecha</label>
                <div class="d-flex align-items-center gap-1">
                    <button class="btn btn-sm eb-date-nav-btn" @onclick="EmergencyPrevDay"
                            disabled="@(_emergencyDate <= _today)" title="Día anterior">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <input type="date" id="erDate" class="form-control form-control-sm"
                            value="@_emergencyDate.ToString("yyyy-MM-dd")"
                            min="@_today.ToString("yyyy-MM-dd")"
                            max="@_today.AddDays(7).ToString("yyyy-MM-dd")"
                            @onchange="OnEmergencyDateChanged" />
                    <button class="btn btn-sm eb-date-nav-btn" @onclick="EmergencyNextDay"
                            disabled="@(_emergencyDate >= _today.AddDays(7))" title="Día siguiente">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
            <div class="col-lg-5 d-flex align-items-end">
                <div class="d-flex align-items-center gap-2 pb-1 flex-wrap">
                    <span class="eb-legend-dot bg-success"></span><span class="small text-muted">Libre</span>
                    <span class="eb-legend-dot bg-warning"></span><span class="small text-muted">Parcial</span>
                    <span class="eb-legend-dot bg-danger"></span><span class="small text-muted">Completo</span>
                    <span class="eb-legend-dot bg-secondary"></span><span class="small text-muted">Bloqueado</span>
                </div>
            </div>
        </div>

        <!-- Mapa de puestos (igual que DockMap) -->
        @if (_emergencyDockMap is not null)
        {
            <div class="d-flex flex-wrap gap-3 mb-3">
                @foreach (var zone in _emergencyDockMap.Zones)
                {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-1 px-2">
                            <i class="bi bi-grid-3x3 text-primary"></i>
                            <span class="fw-semibold small">@zone.Name</span>
                        </div>
                        <div class="card-body py-2 px-3">
                            <div class="d-flex @GetZoneFlexClass(zone) gap-3">
                                @foreach (var table in zone.Tables)
                                {
                                    <div class="eb-table-block">
                                        <p class="text-muted small fw-semibold mb-1">@(table.Locator ?? table.Name)</p>
                                        <div class="eb-dock-table">
                                            <div class="d-flex gap-2 mb-1">
                                                @foreach (var seat in table.SideA)
                                                {
                                                    <span title="@GetTooltip(seat)" style="display:inline-block">
                                                        <button class="btn @GetBtnClass(seat) eb-dock-seat"
                                                                disabled="@(seat.Status is DockStatus.FullyBooked or DockStatus.Blocked)"
                                                                @onclick="() => OnEmergencySeatClicked(seat)">
                                                            @seat.Code
                                                        </button>
                                                    </span>
                                                }
                                            </div>
                                            <hr class="eb-dock-divider my-1" />
                                            <div class="d-flex gap-2">
                                                @foreach (var seat in table.SideB)
                                                {
                                                    <span title="@GetTooltip(seat)" style="display:inline-block">
                                                        <button class="btn @GetBtnClass(seat) eb-dock-seat"
                                                                disabled="@(seat.Status is DockStatus.FullyBooked or DockStatus.Blocked)"
                                                                @onclick="() => OnEmergencySeatClicked(seat)">
                                                            @seat.Code
                                                        </button>
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        @if (_emergencyError is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span class="small">@_emergencyError</span>
            </div>
        }
        @if (_emergencySuccess is not null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-2">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span class="small">@_emergencySuccess</span>
            </div>
        }
    }

    <!-- ═══ PESTAÑA: GESTIÓN DE USUARIOS ══════════════════════════════ -->        
    @if (_activeTab == Tab.Users)
    {
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Modifica los roles de los usuarios para gestionar sus permisos. El rol <strong>Manager</strong> permite gestionar bloqueos de puestos, mientras que el rol <strong>SystemAdmin</strong> otorga acceso completo a este panel.
        </p>
        @if (_allUsers.Count == 0)
        {
            <p class="text-muted small p-3 mb-0">
                <i class="bi bi-info-circle me-1"></i>No hay usuarios registrados.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Nombre</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th class="pe-3 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in UsersPagedItems)
                        {
                            var uid = user.Id;
                            var hasManager = user.Roles.Contains("Manager");
                            var hasAdmin = user.Roles.Contains("SystemAdmin");
                            <tr>
                                <td class="ps-3 fw-semibold small">@user.Name</td>
                                <td class="small text-muted">@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge @GetRoleBadgeClass(role) me-1">@role</span>
                                    }
                                    @if (!user.Roles.Any())
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="pe-3 text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (hasManager)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    title="Quitar rol Manager"
                                                    @onclick="() => RemoveRole(uid, RoleManager)">
                                                <i class="bi bi-person-dash me-1"></i>Manager
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-primary btn-sm"
                                                    title="Asignar rol Manager"
                                                    @onclick="() => AssignRole(uid, RoleManager)">
                                                <i class="bi bi-person-plus me-1"></i>Manager
                                            </button>
                                        }
                                        @if (hasAdmin)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    title="Quitar rol SystemAdmin"
                                                    @onclick="() => RemoveRole(uid, RoleSystemAdmin)">
                                                <i class="bi bi-shield-minus me-1"></i>SystemAdmin
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-danger btn-sm"
                                                    title="Asignar rol SystemAdmin"
                                                    @onclick="() => AssignRole(uid, RoleSystemAdmin)">
                                                <i class="bi bi-shield-plus me-1"></i>SystemAdmin
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (UsersTotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top small text-muted">
                    <span>Página @_usersPage de @UsersTotalPages</span>
                    <div class="d-flex gap-1">
                        <button class="btn btn-outline-secondary btn-sm"
                                disabled="@(_usersPage == 1)"
                                @onclick="() => _usersPage--">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm"
                                disabled="@(_usersPage == UsersTotalPages)"
                                @onclick="() => _usersPage++">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
        @if (_roleError is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 m-3">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span class="small">@_roleError</span>
            </div>
        }
    }

    <!-- ═══ PESTAÑA: LOG DE AUDITORÍA ════════════════════════════════ -->
    @if (_activeTab == Tab.AuditLog)
    {        
        <p class="text-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Revisa las acciones realizadas por los usuarios en el sistema. Utiliza los filtros para acotar la búsqueda por fecha, tipo de acción o usuario. La información mostrada incluye quién realizó la acción, cuándo y detalles adicionales.
        </p>
        <!-- Filtros -->
        <div class="card-body border-bottom pb-3">
            <div class="row g-2 align-items-end">
                <div class="col-sm-6 col-md-3">
                    <label for="logFrom" class="form-label form-label-sm fw-semibold">Desde</label>
                    <input type="date" id="logFrom" class="form-control form-control-sm"
                            @bind="_auditFromDate" />
                </div>
                <div class="col-sm-6 col-md-3">
                    <label for="logTo" class="form-label form-label-sm fw-semibold">Hasta</label>
                    <input type="date" id="logTo" class="form-control form-control-sm"
                            @bind="_auditToDate" />
                </div>
                <div class="col-sm-6 col-md-3">
                    <label for="logAction" class="form-label form-label-sm fw-semibold">Acción</label>
                    <select id="logAction" class="form-select form-select-sm" @bind="_auditActionFilterStr">
                        <option value="">— Todas —</option>
                        @foreach (var action in Enum.GetValues<AuditAction>())
                        {
                            <option value="@((int)action)">@FormatAuditAction(action)</option>
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-3">
                    <label for="logUser" class="form-label form-label-sm fw-semibold">Usuario</label>
                    <input type="text" id="logUser" class="form-control form-control-sm"
                            placeholder="Buscar..." @bind="_auditUserSearch" />
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12 d-flex justify-content-end">
                    <button class="btn btn-primary btn-sm" @onclick="ApplyAuditFilter">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
        @if (_auditLog.Items.Count == 0)
        {
            <p class="text-muted small p-3 mb-0">
                <i class="bi bi-info-circle me-1"></i>No hay registros para los filtros aplicados.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Fecha / Hora</th>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Detalles</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _auditLog.Items)
                        {
                            <tr>
                                <td class="ps-3 small text-muted text-nowrap">
                                    @entry.Timestamp.ToLocalTime().ToString("dd/MM/yy HH:mm")
                                </td>
                                <td class="small">@(entry.PerformedByName ?? "Sistema")</td>
                                <td>
                                    <span class="badge @GetActionBadgeClass(entry.Action)">
                                        @FormatAuditAction(entry.Action)
                                    </span>
                                </td>
                                <td class="small text-muted">@entry.Details</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Paginación -->
            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top">
                <small class="text-muted">
                    Página @_auditPage de @_auditLog.TotalPages
                    (@_auditLog.TotalCount registros totales)
                </small>
                <div class="d-flex gap-1">
                    <button class="btn btn-outline-secondary btn-sm"
                            disabled="@(_auditPage <= 1)"
                            @onclick="AuditPrevPage">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="btn btn-outline-secondary btn-sm"
                            disabled="@(_auditPage >= _auditLog.TotalPages)"
                            @onclick="AuditNextPage">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    }
}

</div>

<!-- ═══════════════════════════════════════════════════
