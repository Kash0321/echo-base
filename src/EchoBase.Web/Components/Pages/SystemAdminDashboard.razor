    // ── Drag & Drop — Reordenación de zonas ─────────────────────────────────

    private async Task OnZoneDrop(Guid targetZoneId)
    {
        if (_dragSourceZoneId is null || _dragSourceZoneId == targetZoneId) return;

        var sourceId = _dragSourceZoneId.Value;
        _dragSourceZoneId = null;

        var orderedIds = _dockZones.Select(z => z.Id).ToList();
        var si = orderedIds.IndexOf(sourceId);
        var ti = orderedIds.IndexOf(targetZoneId);
        if (si < 0 || ti < 0) return;

        orderedIds.RemoveAt(si);
        orderedIds.Insert(ti, sourceId);

        _dcError = null;
        var result = await Mediator.Send(new ReorderDockZonesCommand(CurrentUser.UserId, orderedIds));
        if (result.IsSuccess) await LoadDockConfigAsync();
        else _dcError = MapDockAdminError(result.Error!);
    }

    // ── Drag & Drop — Reordenación de mesas dentro de una zona ─────────────

    private async Task OnTableDrop(Guid targetTableId, DockZoneAdminDto zone)
    {
        if (_dragSourceTableId is null || _dragSourceTableId == targetTableId) return;
        if (_dragTableSourceZoneId != zone.Id) return; // no se permiten cruces de zona

        var sourceId = _dragSourceTableId.Value;
        _dragSourceTableId = null;
        _dragTableSourceZoneId = null;

        var orderedIds = zone.Tables.Select(t => t.Id).ToList();
        var si = orderedIds.IndexOf(sourceId);
        var ti = orderedIds.IndexOf(targetTableId);
        if (si < 0 || ti < 0) return;

        orderedIds.RemoveAt(si);
        orderedIds.Insert(ti, sourceId);

        _dcError = null;
        var result = await Mediator.Send(new ReorderDockTablesCommand(CurrentUser.UserId, zone.Id, orderedIds));
        if (result.IsSuccess) await LoadDockConfigAsync();
        else _dcError = MapDockAdminError(result.Error!);
    }

