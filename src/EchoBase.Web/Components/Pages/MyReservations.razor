@page "/mis-reservas"
@attribute [Authorize]
@rendermode InteractiveServer

@using EchoBase.Core.Common
@using EchoBase.Core.Entities.Enums
@using EchoBase.Core.Reservations.Commands
@using EchoBase.Core.Reservations.Queries
@using EchoBase.Web.Services
@using MediatR

@inject IMediator Mediator
@inject BlazorCurrentUserService CurrentUser

<PageTitle>Mis reservas — Echo Base</PageTitle>

<!-- ═══════════════════════════════════════════════════
     CABECERA DE PÁGINA
═══════════════════════════════════════════════════ -->
<div class="eb-page-header text-white py-2 mb-3">
    <div class="container-fluid px-3">
        <p class="eb-page-eyebrow text-uppercase fw-semibold mb-0">Echo Base</p>
        <h1 class="h4 fw-bold mb-0">
            <i class="bi bi-calendar-check-fill me-2"></i>Mis reservas
        </h1>
    </div>
</div>

<div class="container-fluid px-3">

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (_reservations is not null)
{
    @if (_reservations.Count == 0)
    {
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center py-5">
                <i class="bi bi-calendar-x text-secondary" style="font-size:3rem;"></i>
                <p class="mt-3 text-secondary">No tienes reservas registradas.</p>
                <a href="reservas" class="btn btn-primary btn-sm mt-1">
                    <i class="bi bi-calendar-plus me-1"></i>Hacer una reserva
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- ── Próximas reservas ──────────────────────────── -->
        @if (_futureReservations.Count > 0)
        {
            <div class="mb-4">
                <h2 class="h6 text-uppercase fw-bold text-secondary mb-2 d-flex align-items-center gap-2">
                    <i class="bi bi-clock-history text-primary"></i>Próximas reservas
                    <span class="badge bg-primary rounded-pill">@_futureReservations.Count</span>
                </h2>
                <div class="row g-2">
                    @foreach (var r in _futureReservations)
                    {
                        <div class="col-sm-6 col-lg-4 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 eb-reservation-card">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge bg-primary fs-6 fw-bold eb-dock-badge">@r.DockCode</span>
                                        @FormatStatus(r.Status)
                                    </div>
                                    <p class="mb-1 small">
                                        <i class="bi bi-calendar3 text-secondary me-1"></i>
                                        <strong>@r.Date.ToString("dd/MM/yyyy")</strong>
                                    </p>
                                    <p class="mb-2 small text-secondary">
                                        <i class="bi bi-clock me-1"></i>@FormatSlot(r.TimeSlot)
                                    </p>
                                    @if (r.CanCancel)
                                    {
                                        <button class="btn btn-sm btn-outline-danger w-100"
                                                disabled="@(_cancellingId == r.Id)"
                                                @onclick="() => CancelReservation(r.Id)">
                                            @if (_cancellingId == r.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-x-circle me-1"></i>
                                            }
                                            Cancelar
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── Historial ──────────────────────────────────── -->
        @if (_pastReservations.Count > 0)
        {
            <div>
                <h2 class="h6 text-uppercase fw-bold text-secondary mb-2 d-flex align-items-center gap-2">
                    <i class="bi bi-archive text-secondary"></i>Historial
                </h2>
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="eb-table-head">
                                <tr>
                                    <th class="ps-3">Fecha</th>
                                    <th>Puesto</th>
                                    <th>Franja</th>
                                    <th class="pe-3">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _pastReservations)
                                {
                                    <tr class="@(r.Status == ReservationStatus.Cancelled ? "eb-row-cancelled" : "")">
                                        <td class="ps-3 small">@r.Date.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge @(r.Status == ReservationStatus.Cancelled ? "bg-secondary" : "bg-primary")">@r.DockCode</span></td>
                                        <td class="small text-secondary">@FormatSlot(r.TimeSlot)</td>
                                        <td class="pe-3">@FormatStatus(r.Status)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
}

<!-- ── Notificaciones ──────────────────────────────────── -->
@if (_cancelError is not null)
{
    <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2 mt-3">
        <i class="bi bi-x-circle-fill flex-shrink-0"></i>
        <span>@_cancelError</span>
        <button type="button" class="btn-close ms-auto" @onclick="() => _cancelError = null"></button>
    </div>
}

@if (_cancelSuccess)
{
    <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 mt-3">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>Reserva cancelada correctamente.</span>
        <button type="button" class="btn-close ms-auto" @onclick="() => _cancelSuccess = false"></button>
    </div>
}

</div>

@code {
    private IReadOnlyList<UserReservationDto>? _reservations;
    private List<UserReservationDto> _futureReservations = [];
    private List<UserReservationDto> _pastReservations = [];
    private bool _loading = true;
    private Guid? _cancellingId;
    private string? _cancelError;
    private bool _cancelSuccess;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.InitializeAsync();
        await LoadReservationsAsync();
    }

    private async Task LoadReservationsAsync()
    {
        _loading = true;
        _reservations = await Mediator.Send(new GetUserReservationsQuery(CurrentUser.UserId));

        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        _futureReservations = _reservations
            .Where(r => r.Date >= today && r.Status == ReservationStatus.Active)
            .OrderBy(r => r.Date)
            .ToList();
        _pastReservations = _reservations
            .Where(r => r.Date < today || r.Status == ReservationStatus.Cancelled)
            .OrderByDescending(r => r.Date)
            .ToList();

        _loading = false;
    }

    private async Task CancelReservation(Guid reservationId)
    {
        _cancellingId = reservationId;
        _cancelError = null;
        _cancelSuccess = false;

        var command = new CancelReservationCommand(reservationId, CurrentUser.UserId);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            _cancelSuccess = true;
            await LoadReservationsAsync();
        }
        else
        {
            _cancelError = MapError(result.Error!);
        }

        _cancellingId = null;
    }

    private static string FormatSlot(TimeSlot slot) => slot switch
    {
        TimeSlot.Morning => "Mañana",
        TimeSlot.Afternoon => "Tarde",
        TimeSlot.Both => "Mañana y Tarde",
        _ => slot.ToString()
    };

    private static MarkupString FormatStatus(ReservationStatus status) => status switch
    {
        ReservationStatus.Active => new("<span class=\"badge bg-success\">Activa</span>"),
        ReservationStatus.Cancelled => new("<span class=\"badge bg-secondary\">Cancelada</span>"),
        _ => new($"<span class=\"badge bg-light text-dark\">{status}</span>")
    };

    private static string MapError(string error) => error switch
    {
        "RESERVATION_NOT_FOUND" => "La reserva no existe.",
        "NOT_RESERVATION_OWNER" => "No puedes cancelar una reserva que no te pertenece.",
        "ALREADY_CANCELLED" => "La reserva ya fue cancelada anteriormente.",
        _ => $"Error inesperado: {error}"
    };
}
