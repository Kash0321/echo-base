@page "/mis-reservas"
@attribute [Authorize]
@rendermode InteractiveServer

@using EchoBase.Core.Common
@using EchoBase.Core.Entities.Enums
@using EchoBase.Core.Reservations.Commands
@using EchoBase.Core.Reservations.Queries
@using EchoBase.Web.Services
@using MediatR

@inject IMediator Mediator
@inject BlazorCurrentUserService CurrentUser

<PageTitle>Mis reservas</PageTitle>

<h1 class="mb-3">Mis reservas</h1>

@if (_loading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (_reservations is not null)
{
    @if (_reservations.Count == 0)
    {
        <div class="alert alert-info">No tienes reservas registradas.</div>
    }
    else
    {
        <!-- Reservas futuras activas -->
        @if (_futureReservations.Count > 0)
        {
            <h4 class="mt-4 mb-3">Próximas reservas</h4>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Puesto</th>
                            <th>Franja</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _futureReservations)
                        {
                            <tr>
                                <td>@r.Date.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-primary">@r.DockCode</span></td>
                                <td>@FormatSlot(r.TimeSlot)</td>
                                <td>@FormatStatus(r.Status)</td>
                                <td>
                                    @if (r.CanCancel)
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                disabled="@(_cancellingId == r.Id)"
                                                @onclick="() => CancelReservation(r.Id)">
                                            @if (_cancellingId == r.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            Cancelar
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Historial de reservas pasadas -->
        @if (_pastReservations.Count > 0)
        {
            <h4 class="mt-4 mb-3">Historial</h4>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-secondary">
                        <tr>
                            <th>Fecha</th>
                            <th>Puesto</th>
                            <th>Franja</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _pastReservations)
                        {
                            <tr class="@(r.Status == ReservationStatus.Cancelled ? "text-decoration-line-through text-muted" : "")">
                                <td>@r.Date.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-secondary">@r.DockCode</span></td>
                                <td>@FormatSlot(r.TimeSlot)</td>
                                <td>@FormatStatus(r.Status)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}

@if (_cancelError is not null)
{
    <div class="alert alert-danger alert-dismissible mt-3">
        @_cancelError
        <button type="button" class="btn-close" @onclick="() => _cancelError = null"></button>
    </div>
}

@if (_cancelSuccess)
{
    <div class="alert alert-success alert-dismissible mt-3">
        Reserva cancelada correctamente.
        <button type="button" class="btn-close" @onclick="() => _cancelSuccess = false"></button>
    </div>
}

@code {
    private IReadOnlyList<UserReservationDto>? _reservations;
    private List<UserReservationDto> _futureReservations = [];
    private List<UserReservationDto> _pastReservations = [];
    private bool _loading = true;
    private Guid? _cancellingId;
    private string? _cancelError;
    private bool _cancelSuccess;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.InitializeAsync();
        await LoadReservationsAsync();
    }

    private async Task LoadReservationsAsync()
    {
        _loading = true;
        _reservations = await Mediator.Send(new GetUserReservationsQuery(CurrentUser.UserId));

        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        _futureReservations = _reservations
            .Where(r => r.Date >= today && r.Status == ReservationStatus.Active)
            .OrderBy(r => r.Date)
            .ToList();
        _pastReservations = _reservations
            .Where(r => r.Date < today || r.Status == ReservationStatus.Cancelled)
            .OrderByDescending(r => r.Date)
            .ToList();

        _loading = false;
    }

    private async Task CancelReservation(Guid reservationId)
    {
        _cancellingId = reservationId;
        _cancelError = null;
        _cancelSuccess = false;

        var command = new CancelReservationCommand(reservationId, CurrentUser.UserId);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            _cancelSuccess = true;
            await LoadReservationsAsync();
        }
        else
        {
            _cancelError = MapError(result.Error!);
        }

        _cancellingId = null;
    }

    private static string FormatSlot(TimeSlot slot) => slot switch
    {
        TimeSlot.Morning => "Mañana",
        TimeSlot.Afternoon => "Tarde",
        TimeSlot.Both => "Mañana y Tarde",
        _ => slot.ToString()
    };

    private static MarkupString FormatStatus(ReservationStatus status) => status switch
    {
        ReservationStatus.Active => new("<span class=\"badge bg-success\">Activa</span>"),
        ReservationStatus.Cancelled => new("<span class=\"badge bg-secondary\">Cancelada</span>"),
        _ => new($"<span class=\"badge bg-light text-dark\">{status}</span>")
    };

    private static string MapError(string error) => error switch
    {
        "RESERVATION_NOT_FOUND" => "La reserva no existe.",
        "NOT_RESERVATION_OWNER" => "No puedes cancelar una reserva que no te pertenece.",
        "ALREADY_CANCELLED" => "La reserva ya fue cancelada anteriormente.",
        _ => $"Error inesperado: {error}"
    };
}
