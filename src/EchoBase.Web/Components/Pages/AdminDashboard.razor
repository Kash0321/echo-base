@page "/admin"
@attribute [Authorize(Roles = "Manager")]
@rendermode InteractiveServer

@using EchoBase.Core.BlockedDocks.Commands
@using EchoBase.Core.BlockedDocks.Queries
@using EchoBase.Core.Entities.Enums
@using EchoBase.Core.Incidences
@using EchoBase.Core.Incidences.Commands
@using EchoBase.Core.Incidences.Queries
@using EchoBase.Core.Interfaces
@using EchoBase.Core.Reservations.Queries
@using EchoBase.Core.SystemAdmin.Queries
@using EchoBase.Web.Services
@using MediatR

@inject IMediator Mediator
@inject BlazorCurrentUserService CurrentUser

<PageTitle>Cuadro de mando — Echo Base</PageTitle>

<!-- ═══════════════════════════════════════════════════
     CABECERA DE PÁGINA
═══════════════════════════════════════════════════ -->
<div class="eb-page-header text-white py-2 mb-3">
    <div class="container-fluid px-3">
        <p class="eb-page-eyebrow text-uppercase fw-semibold mb-0">Echo Base</p>
        <h1 class="h4 fw-bold mb-0">
            <i class="bi bi-toggles2 me-2"></i>Gestión avanzada
        </h1>
    </div>
</div>

<div class="container-fluid px-3">
    <p class="text-info small mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Desde este panel de administración, puedes gestionar bloqueos de puestos para mantenimiento u otras incidencias. Selecciona los puestos afectados en el mapa, define el período de bloqueo y el motivo. También puedes revisar y eliminar bloqueos activos. Ten en cuenta que bloquear un puesto cancelará automáticamente cualquier reserva existente para ese período.
    </p>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    <!-- ═══════════════════════ BLOQUEO + MAPA ═══════════════════════ -->
    <div class="row g-3">

        <!-- Panel de bloqueo -->
        <div class="col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-2">
                    <i class="bi bi-slash-circle text-danger fs-5"></i>
                    <span class="fw-semibold">Bloquear puestos</span>
                </div>
                <div class="card-body">

                    <!-- Puestos seleccionados -->
                    <label class="form-label form-label-sm fw-semibold">Puestos seleccionados</label>
                    @if (_selectedDockIds.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-1 mb-3">
                            @foreach (var dockId in _selectedDockIds)
                            {
                                <span class="badge bg-primary d-flex align-items-center gap-1">
                                    @GetDockCode(dockId)
                                    <button type="button"
                                            class="btn-close btn-close-white ms-1"
                                            style="font-size:.5rem;"
                                            title="Quitar"
                                            @onclick="() => ToggleDock(dockId)"></button>
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-3">
                            <i class="bi bi-hand-index me-1"></i>Haz clic en el mapa para seleccionar puestos.
                        </p>
                    }

                    <!-- Fechas -->
                    <div class="mb-2">
                        <label for="blockStart" class="form-label form-label-sm fw-semibold">Fecha inicio</label>
                        <input type="date" id="blockStart" class="form-control form-control-sm"
                               value="@_blockStartDate.ToString("yyyy-MM-dd")"
                               min="@_today.ToString("yyyy-MM-dd")"
                               @onchange="OnStartDateChanged" />
                    </div>
                    <div class="mb-2">
                        <label for="blockEnd" class="form-label form-label-sm fw-semibold">Fecha fin</label>
                        <input type="date" id="blockEnd" class="form-control form-control-sm"
                               value="@_blockEndDate.ToString("yyyy-MM-dd")"
                               min="@_blockStartDate.ToString("yyyy-MM-dd")"
                               @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _blockEndDate = d; _blockError = null; _blockSuccess = null; }" />
                    </div>
                    <div class="mb-3">
                        <label for="blockReason" class="form-label form-label-sm fw-semibold">Motivo</label>
                        <input type="text" id="blockReason" class="form-control form-control-sm"
                               placeholder="Ej: Mantenimiento eléctrico..."
                               @bind="_blockReason" />
                    </div>

                    <!-- Feedback -->
                    @if (_blockError is not null)
                    {
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-2">
                            <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                            <span class="small">@_blockError</span>
                        </div>
                    }
                    @if (_blockSuccess is not null)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-2">
                            <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                            <span class="small">@_blockSuccess</span>
                        </div>
                    }

                    <!-- Botón bloquear -->
                    <button class="btn btn-danger btn-sm w-100"
                            disabled="@(_selectedDockIds.Count == 0 || string.IsNullOrWhiteSpace(_blockReason) || _blocking)"
                            @onclick="BlockSelectedDocks">
                        @if (_blocking)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-slash-circle me-1"></i>
                        }
                        Bloquear selección
                        @if (_selectedDockIds.Count > 0)
                        {
                            <span>(@_selectedDockIds.Count)</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <!-- Mapa de puestos (multiselección) -->
        <div class="col-lg-8 col-xl-9">
            @if (_dockMap is not null)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-2">
                        <i class="bi bi-map-fill text-primary fs-5"></i>
                        <span class="fw-semibold">Selección de puestos</span>
                        <span class="text-muted small ms-auto">
                            <i class="bi bi-hand-index me-1"></i>Clic para seleccionar · Bloqueados deshabilitados
                        </span>
                    </div>
                    <div class="card-body py-2 px-3">
                        <div class="row g-3">
                            @foreach (var zone in _dockMap.Zones)
                            {
                                <div class="col-12">
                                    <p class="text-muted small fw-semibold mb-2">
                                        <i class="bi bi-grid-3x3 text-primary me-1"></i>@zone.Name
                                    </p>
                                    <div class="d-flex @GetZoneFlexClass(zone) gap-3">
                                        @foreach (var table in zone.Tables)
                                        {
                                            <div class="eb-table-block">
                                                <p class="text-muted small fw-semibold mb-1">@(table.Locator ?? table.Name)</p>
                                                <div class="eb-dock-table">
                                                    <div class="d-flex gap-2 mb-1">
                                                        @foreach (var seat in table.SideA)
                                                        {
                                                            <span title="@GetAdminTooltip(seat)" style="display:inline-block">
                                                                <button class="btn @GetSeatBtnClass(seat) eb-dock-seat"
                                                                        disabled="@IsSeatDisabled(seat)"
                                                                        @onclick="() => ToggleDock(seat.Id)">
                                                                    @seat.Code
                                                                </button>
                                                            </span>
                                                        }
                                                    </div>
                                                    <hr class="eb-dock-divider my-1" />
                                                    <div class="d-flex gap-2">
                                                        @foreach (var seat in table.SideB)
                                                        {
                                                            <span title="@GetAdminTooltip(seat)" style="display:inline-block">
                                                                <button class="btn @GetSeatBtnClass(seat) eb-dock-seat"
                                                                        disabled="@IsSeatDisabled(seat)"
                                                                        @onclick="() => ToggleDock(seat.Id)">
                                                                    @seat.Code
                                                                </button>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ═══════════════════════ BLOQUEOS ACTIVOS ═══════════════════════ -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-2">
                    <i class="bi bi-list-check text-primary fs-5"></i>
                    <span class="fw-semibold">Bloqueos activos</span>
                    <span class="badge bg-secondary ms-auto">@_activeBlocks.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (_activeBlocks.Count == 0)
                    {
                        <p class="text-muted small p-3 mb-0">
                            <i class="bi bi-info-circle me-1"></i>No hay bloqueos activos actualmente.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">Puesto</th>
                                        <th>Fecha inicio</th>
                                        <th>Fecha fin</th>
                                        <th>Motivo</th>
                                        <th>Bloqueado por</th>
                                        <th class="pe-3 text-end">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var block in BlocksPagedItems)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <span class="badge bg-secondary">@block.DockCode</span>
                                            </td>
                                            <td class="small">@block.StartDate.ToString("dd/MM/yyyy")</td>
                                            <td class="small">
                                                @block.EndDate.ToString("dd/MM/yyyy")
                                                @if (block.EndDate < _today)
                                                {
                                                    <span class="badge bg-light text-secondary ms-1">Pasado</span>
                                                }
                                            </td>
                                            <td class="small">@block.Reason</td>
                                            <td class="small text-muted">@block.BlockedByName</td>
                                            <td class="pe-3 text-end">
                                                <button class="btn btn-outline-danger btn-sm"
                                                        disabled="@(_unblockingId == block.BlockId)"
                                                        title="Desbloquear puesto"
                                                        @onclick="() => UnblockAsync(block.BlockId)">
                                                    @if (_unblockingId == block.BlockId)
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-unlock"></i>
                                                    }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (BlocksTotalPages > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top small text-muted">
                                <span>Página @_blocksPage de @BlocksTotalPages</span>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            disabled="@(_blocksPage == 1)"
                                            @onclick="() => _blocksPage--">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            disabled="@(_blocksPage == BlocksTotalPages)"
                                            @onclick="() => _blocksPage++">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════ INCIDENCIAS ═══════════════════════ -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header eb-zone-header d-flex align-items-center gap-2 py-2">
                    <i class="bi bi-exclamation-triangle text-warning fs-5"></i>
                    <span class="fw-semibold">Incidencias en puestos</span>
                    @if (_allIncidences is not null)
                    {
                        <span class="badge bg-secondary ms-auto">@_allIncidences.TotalCount</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_loadingIncidences)
                    {
                        <div class="d-flex justify-content-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                        </div>
                    }
                    else if (_allIncidences is null || _allIncidences.TotalCount == 0)
                    {
                        <p class="text-muted small p-3 mb-0">
                            <i class="bi bi-info-circle me-1"></i>No hay incidencias registradas actualmente.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">Puesto</th>
                                        <th>Reportado por</th>
                                        <th>Descripción</th>
                                        <th>Estado</th>
                                        <th>Fecha</th>
                                        <th class="pe-3 text-end">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var inc in _allIncidences.Items)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <span class="badge bg-dark">@inc.DockCode</span>
                                                @if (!string.IsNullOrEmpty(inc.DockLocation))
                                                {
                                                    <br /><small class="text-muted">@inc.DockLocation</small>
                                                }
                                            </td>
                                            <td class="small">
                                                @inc.ReporterName
                                                <br /><span class="text-muted">@inc.ReporterEmail</span>
                                            </td>
                                            <td>
                                                <span class="text-truncate d-inline-block" style="max-width:18rem;" title="@inc.Description">
                                                    @inc.Description
                                                </span>
                                            </td>
                                            <td>@IncidenceStatusBadge(inc.Status)</td>
                                            <td><span class="text-nowrap small">@inc.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></td>
                                            <td class="pe-3 text-end">
                                                <button class="btn btn-outline-primary btn-sm"
                                                        title="Actualizar estado"
                                                        @onclick="() => OpenUpdateModal(inc)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (IncidencesTotalPages > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top small text-muted">
                                <span>Página @_incidencesPage de @IncidencesTotalPages</span>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            disabled="@(_incidencesPage == 1)"
                                            @onclick="GoToPrevIncidencesPage">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            disabled="@(_incidencesPage == IncidencesTotalPages)"
                                            @onclick="GoToNextIncidencesPage">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════
     MODAL ACTUALIZACIÓN DE ESTADO DE INCIDENCIA
═══════════════════════════════════════════════════ -->
@if (_updateIncidenceId is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="CloseUpdateModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content border-0 shadow">
                <div class="modal-header eb-modal-header">
                    <div>
                        <p class="eb-page-eyebrow text-uppercase fw-semibold text-white-50 mb-0" style="font-size:.65rem;letter-spacing:.15em;">Gestionar incidencia</p>
                        <h5 class="modal-title text-white fw-bold mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Puesto @_updateDockCode
                        </h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseUpdateModal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted fst-italic mb-3">@_updateDescription</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold form-label-sm">Nuevo estado</label>
                        <select class="form-select form-select-sm" @bind="_updateNewStatus">
                            <option value="@IncidenceStatus.Open">Abierta</option>
                            <option value="@IncidenceStatus.UnderReview">En revisión</option>
                            <option value="@IncidenceStatus.Resolved">Resuelta</option>
                            <option value="@IncidenceStatus.Rejected">Rechazada</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold form-label-sm" for="managerComment">Comentario (opcional)</label>
                        <textarea id="managerComment"
                                  class="form-control form-control-sm"
                                  rows="3"
                                  placeholder="Indica qué acción se ha tomado o por qué se rechaza…"
                                  maxlength="2000"
                                  @bind="_updateComment"
                                  @bind:event="oninput"></textarea>
                        <div class="d-flex justify-content-end mt-1">
                            <small class="text-muted">@(_updateComment?.Length ?? 0)/2000</small>
                        </div>
                    </div>

                    @if (_updateError is not null)
                    {
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mt-2">
                            <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                            <span class="small">@_updateError</span>
                        </div>
                    }
                    @if (_updateSuccess)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2 py-2 mt-2">
                            <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                            <span class="small">Estado actualizado correctamente.</span>
                        </div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CloseUpdateModal">
                        <i class="bi bi-x me-1"></i>Cerrar
                    </button>
                    @if (!_updateSuccess)
                    {
                        <button type="button" class="btn btn-primary btn-sm"
                                disabled="@_updating"
                                @onclick="SubmitStatusUpdate">
                            @if (_updating)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-check2 me-1"></i>
                            }
                            Guardar
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

</div>

@code {
    // ──────────────────────────────────────────────────────────────
    // Estado: datos de incidencias (Manager view)
    // ──────────────────────────────────────────────────────────────
    private PagedResult<IncidenceReportManagerDto>? _allIncidences;
    private bool _loadingIncidences = true;
    private int _incidencesPage = 1;
    private const int IncidencesPageSize = 20;
    private int IncidencesTotalPages =>
        _allIncidences is null ? 1 : (int)Math.Ceiling(_allIncidences.TotalCount / (double)IncidencesPageSize);

    // ──────────────────────────────────────────────────────────────
    // Estado: modal de actualización de estado de incidencia
    // ──────────────────────────────────────────────────────────────
    private Guid? _updateIncidenceId;
    private string? _updateDockCode;
    private string? _updateDescription;
    private IncidenceStatus _updateNewStatus;
    private string? _updateComment;
    private string? _updateError;
    private bool _updateSuccess;
    private bool _updating;

    // ──────────────────────────────────────────────────────────────
    // Estado: fechas y formulario de bloqueo
    // ──────────────────────────────────────────────────────────────
    private DateOnly _today;
    private DateOnly _blockStartDate;
    private DateOnly _blockEndDate;
    private string _blockReason = string.Empty;
    private string? _blockError;
    private string? _blockSuccess;
    private bool _blocking;

    // ──────────────────────────────────────────────────────────────
    // Estado: datos cargados
    // ──────────────────────────────────────────────────────────────
    private DockMapDto? _dockMap;
    private IReadOnlyList<ActiveBlockDto> _activeBlocks = [];
    private bool _loading = true;

    // ──────────────────────────────────────────────────────────────
    // Estado: selección y desbloqueo
    // ──────────────────────────────────────────────────────────────
    private readonly HashSet<Guid> _selectedDockIds = new();
    private Guid? _unblockingId;

    // ──────────────────────────────────────────────────────────────
    // Estado: paginación de bloqueos activos
    // ──────────────────────────────────────────────────────────────
    private const int BlocksPageSize = 10;
    private int _blocksPage = 1;
    private int BlocksTotalPages => (int)Math.Ceiling(_activeBlocks.Count / (double)BlocksPageSize);
    private IEnumerable<ActiveBlockDto> BlocksPagedItems =>
        _activeBlocks.Skip((_blocksPage - 1) * BlocksPageSize).Take(BlocksPageSize);

    // ══════════════════════════════════════════════════════════════
    // Ciclo de vida
    // ══════════════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.InitializeAsync();
        _today = DateOnly.FromDateTime(DateTime.UtcNow);
        _blockStartDate = _today;
        _blockEndDate = _today;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _dockMap = await Mediator.Send(new GetDockMapQuery(_blockStartDate));
        _activeBlocks = await Mediator.Send(new GetActiveBlocksQuery());
        _blocksPage = 1;
        _loading = false;
        await LoadAllIncidencesAsync();
    }

    // ══════════════════════════════════════════════════════════════
    // Interacciones de formulario
    // ══════════════════════════════════════════════════════════════

    private async Task OnStartDateChanged(ChangeEventArgs e)
    {
        if (!DateOnly.TryParse(e.Value?.ToString(), out var date)) return;

        _blockStartDate = date;
        if (_blockEndDate < _blockStartDate)
            _blockEndDate = _blockStartDate;

        _blockError = null;
        _blockSuccess = null;
        _dockMap = await Mediator.Send(new GetDockMapQuery(_blockStartDate));
    }

    private void ToggleDock(Guid dockId)
    {
        if (!_selectedDockIds.Remove(dockId))
            _selectedDockIds.Add(dockId);

        _blockError = null;
        _blockSuccess = null;
    }

    // ══════════════════════════════════════════════════════════════
    // Operaciones de bloqueo / desbloqueo
    // ══════════════════════════════════════════════════════════════

    private async Task BlockSelectedDocks()
    {
        if (_selectedDockIds.Count == 0 || string.IsNullOrWhiteSpace(_blockReason)) return;

        _blocking = true;
        _blockError = null;
        _blockSuccess = null;

        var command = new BlockDocksCommand(
            CurrentUser.UserId,
            _selectedDockIds.ToList(),
            _blockStartDate,
            _blockEndDate,
            _blockReason.Trim());

        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            var cancelledCount = result.Value!.CancelledReservationIds.Count;
            _blockSuccess = cancelledCount > 0
                ? $"Se han bloqueado {result.Value.BlockedDockIds.Count} puesto(s). " +
                  $"Se han cancelado automáticamente {cancelledCount} reserva(s) existente(s)."
                : $"Se han bloqueado {result.Value.BlockedDockIds.Count} puesto(s) correctamente.";

            _selectedDockIds.Clear();
            _blockReason = string.Empty;
            await LoadDataAsync();
        }
        else
        {
            _blockError = MapBlockError(result.Error!);
        }

        _blocking = false;
    }

    private async Task UnblockAsync(Guid blockId)
    {
        _unblockingId = blockId;

        var command = new UnblockDocksCommand(CurrentUser.UserId, [blockId]);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
            await LoadDataAsync();

        _unblockingId = null;
    }

    // ══════════════════════════════════════════════════════════════
    // Helpers visuales
    // ══════════════════════════════════════════════════════════════

    private string? GetDockCode(Guid dockId)
    {
        if (_dockMap is null) return dockId.ToString()[..8];
        foreach (var zone in _dockMap.Zones)
        foreach (var table in zone.Tables)
        {
            var seat = table.SideA.FirstOrDefault(s => s.Id == dockId)
                    ?? table.SideB.FirstOrDefault(s => s.Id == dockId);
            if (seat is not null) return seat.Code;
        }
        return dockId.ToString()[..8];
    }

    private string GetSeatBtnClass(DockSeatDto seat)
    {
        if (_selectedDockIds.Contains(seat.Id)) return "btn-primary";
        return seat.Status switch
        {
            DockStatus.Free           => "btn-outline-success",
            DockStatus.PartiallyBooked => "btn-outline-warning",
            DockStatus.FullyBooked    => "btn-outline-danger",
            DockStatus.Blocked        => "btn-secondary",
            _                         => "btn-outline-secondary"
        };
    }

    private static string GetZoneFlexClass(DockZoneMapDto zone) =>
        zone.Orientation == ZoneOrientation.Vertical ? "flex-column align-items-start" : "flex-row flex-wrap";

    private bool IsSeatDisabled(DockSeatDto seat)
        => seat.Status == DockStatus.Blocked && !_selectedDockIds.Contains(seat.Id);

    private string GetAdminTooltip(DockSeatDto seat)
    {
        if (_selectedDockIds.Contains(seat.Id)) return "Seleccionado — clic para quitar";
        return seat.Status switch
        {
            DockStatus.Free            => "Libre — clic para seleccionar",
            DockStatus.PartiallyBooked => BuildAdminPartialTooltip(seat),
            DockStatus.FullyBooked     => BuildAdminFullBookedTooltip(seat),
            DockStatus.Blocked         => "Ya bloqueado — no se puede seleccionar",
            _                          => seat.Code
        };
    }

    private static string BuildAdminPartialTooltip(DockSeatDto seat)
    {
        var slot = FormatSlot(seat.BookedSlot!.Value);
        var who = seat.BookedSlot!.Value == TimeSlot.Morning ? seat.MorningBookedBy : seat.AfternoonBookedBy;
        var whoText = string.IsNullOrEmpty(who) ? "" : $" ({who})";
        return $"Parcial — {slot} ocupada{whoText} — clic para seleccionar (se cancelará la reserva)";
    }

    private static string BuildAdminFullBookedTooltip(DockSeatDto seat)
    {
        var parts = new List<string>();
        if (seat.MorningBookedBy is not null) parts.Add($"Mañana: {seat.MorningBookedBy}");
        if (seat.AfternoonBookedBy is not null) parts.Add($"Tarde: {seat.AfternoonBookedBy}");
        var detailsText = parts.Count > 0 ? $" ({string.Join(", ", parts)})" : "";
        return $"Totalmente reservado{detailsText} — clic para seleccionar (se cancelarán las reservas)";
    }

    private static string FormatSlot(TimeSlot slot) => slot switch
    {
        TimeSlot.Morning   => "Mañana",
        TimeSlot.Afternoon => "Tarde",
        TimeSlot.Both      => "Mañana y Tarde",
        _                  => slot.ToString()
    };

    private static string MapBlockError(string error) => error switch
    {
        "NOT_MANAGER"               => "No tienes permisos de Manager para realizar esta acción.",
        "EMPTY_DOCK_LIST"           => "No has seleccionado ningún puesto.",
        "START_DATE_IN_THE_PAST"    => "La fecha de inicio no puede ser anterior a hoy.",
        "END_DATE_BEFORE_START_DATE" => "La fecha de fin no puede ser anterior a la de inicio.",
        "EMPTY_REASON"              => "Debes introducir un motivo para el bloqueo.",
        "DOCKS_NOT_FOUND"           => "Alguno de los puestos seleccionados no existe.",
        "OVERLAPPING_BLOCKS"        => "Ya existen bloqueos activos para alguno de los puestos en ese período.",
        _                           => $"Error inesperado: {error}"
    };

    // ══════════════════════════════════════════════════════════════
    // Incidencias: carga y paginación
    // ══════════════════════════════════════════════════════════════

    private async Task LoadAllIncidencesAsync()
    {
        _loadingIncidences = true;
        var result = await Mediator.Send(new GetAllIncidencesQuery(CurrentUser.UserId, _incidencesPage, IncidencesPageSize));
        _allIncidences = result.IsSuccess ? result.Value : null;
        _loadingIncidences = false;
    }

    private async Task GoToPrevIncidencesPage()
    {
        if (_incidencesPage > 1) { _incidencesPage--; await LoadAllIncidencesAsync(); }
    }

    private async Task GoToNextIncidencesPage()
    {
        if (_incidencesPage < IncidencesTotalPages) { _incidencesPage++; await LoadAllIncidencesAsync(); }
    }

    // ══════════════════════════════════════════════════════════════
    // Incidencias: modal de actualización de estado
    // ══════════════════════════════════════════════════════════════

    private void OpenUpdateModal(IncidenceReportManagerDto inc)
    {
        _updateIncidenceId = inc.Id;
        _updateDockCode    = inc.DockCode;
        _updateDescription = inc.Description;
        _updateNewStatus   = inc.Status;
        _updateComment     = inc.ManagerComment;
        _updateError       = null;
        _updateSuccess     = false;
    }

    private void CloseUpdateModal()
    {
        _updateIncidenceId = null;
        _updateDockCode    = null;
        _updateDescription = null;
        _updateComment     = null;
        _updateError       = null;
        _updateSuccess     = false;
    }

    private async Task SubmitStatusUpdate()
    {
        if (_updateIncidenceId is null) return;

        _updating    = true;
        _updateError = null;

        var command = new UpdateIncidenceStatusCommand(
            CurrentUser.UserId,
            _updateIncidenceId.Value,
            _updateNewStatus,
            string.IsNullOrWhiteSpace(_updateComment) ? null : _updateComment.Trim());

        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            _updateSuccess = true;
            await LoadAllIncidencesAsync();
        }
        else
        {
            _updateError = result.Error switch
            {
                IncidenceErrors.NotManager       => "No tienes permisos de Manager para actualizar incidencias.",
                IncidenceErrors.IncidenceNotFound => "No se encontró la incidencia.",
                _                                => "Error inesperado al actualizar el estado."
            };
        }

        _updating = false;
    }

    private static RenderFragment IncidenceStatusBadge(IncidenceStatus status) => status switch
    {
        IncidenceStatus.Open        => @<span class="badge bg-secondary">Abierta</span>,
        IncidenceStatus.UnderReview => @<span class="badge bg-warning text-dark">En revisión</span>,
        IncidenceStatus.Resolved    => @<span class="badge bg-success">Resuelta</span>,
        IncidenceStatus.Rejected    => @<span class="badge bg-danger">Rechazada</span>,
        _                           => @<span class="badge bg-light text-dark">@status</span>
    };
}
